<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Style sheets -->
    <link rel="stylesheet" href="/css/index.css" />

    <link rel="stylesheet" href="/css/styles.css" />

    <link rel="stylesheet" href="/css/fileSystem/file.css" />
    <link rel="stylesheet" href="/css/fileSystem/folder.css" />
    <link rel="stylesheet" href="/css/fileSystem/fileList.css" />
    <!-- Scripts -->
    <script src="/js/index.js" defer></script>
    <script type="module" src="/js/fileSystem.js"></script>

    <title>Share-odin</title>
  </head>

  <body>
    <% if (allData?.id) { %>
    <header>
      <nav>
        <button
          class="uploadBtn"
          commandfor="uploadDialog"
          command="show-modal"
        >
          <img src="/assets/icons/upload.svg" alt="Upload icon" />
          Upload
        </button>
        <button
          class="downloadBtn"
          commandfor="downloadDialog"
          command="show-modal"
        >
          <img src="/assets/icons/download.svg" alt="Download icon" />
          Receive
        </button>
      </nav>
    </header>

    <div class="contentBody">
      <%- include('./partials/forms/uploadForm.ejs') %> <%-
      include('./partials/forms/downloadForm.ejs') %> <%-
      include('./partials/downloadPage.ejs') %> <%-
      include('./partials/fileSystem/fileList.ejs') %>
    </div>
    <% } else{ %>

    <%-
      include('./partials/forms/downloadForm.ejs') %>
    <%-
      include('./partials/downloadPage.ejs') %>
    <% } %>
  </body>
</html>
