generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String @id @default(cuid(2)) @db.VarChar(30)
  first_name    String
  last_name     String
  username      String @unique
  password_hash String
  posts         Post[]
}

model Post {
  id          String   @id @default(nanoid(5))
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  file_name   String
  file_size   String
  location    String
  isProtected Boolean  @default(false)
  uploaded_at DateTime @default(now())
  expires_at  DateTime
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
