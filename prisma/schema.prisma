generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String @id @default(cuid(2)) @db.VarChar(30)
  first_name    String
  last_name     String
  username      String @unique
  password_hash String
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
